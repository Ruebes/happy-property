# ── Supabase (Pflichtfelder) ──────────────────────────────────────────────────
# Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service Role Key – wird im Browser für Admin-Funktionen genutzt (ProtectedRoute)
# Supabase Dashboard → Settings → API → service_role key
VITE_SUPABASE_SERVICE_ROLE_KEY=

# ── Google Calendar Integration ───────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Dienste → Anmeldedaten

VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# ── Nur für lokale Scripts (NICHT für Vercel / Produktion) ───────────────────
# Supabase CLI / Migrations

SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
